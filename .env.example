# Flotilla local dev — copy to .env and fill in secrets
# Run: cp .env.example .env

# Fleet Hub
LOCAL_MODE=true
PUBLIC_URL=http://localhost:8787
FLEET_SYNC_TOKEN=

# Google OAuth (leave blank to use LOCAL_MODE)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_AUTH_COOKIE_SECRET=changeme-generate-a-random-string
GOOGLE_AUTH_ALLOWED_EMAILS=

# GitHub live standup sync (optional)
GITHUB_REPO=
GITHUB_BRANCH=master

# Telegram bridge (optional, required for --profile full)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Dispatcher tuning
DISPATCHER_COOLDOWN=300
